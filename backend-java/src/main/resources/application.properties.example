spring.application.name=backend
server.port=8080

spring.datasource.url=jdbc:postgresql://localhost:5433/sapsr_db
spring.datasource.username=sapsr_user
spring.datasource.password=sapsr_password

spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true

# Telegram Bot
telegram.bot.token=ВАШ_ТОКЕН
bot.webapp.url=https://ВАШ_ПОЛЬЗОВАТЕЛЬ.github.io/SAPSR/

# RabbitMQ
spring.rabbitmq.host=localhost
spring.rabbitmq.port=5672
spring.rabbitmq.username=rmq_user
spring.rabbitmq.password=rmq_password
sapsr.rabbitmq.tasks-queue=pdf_tasks_queue
sapsr.rabbitmq.results-queue=pdf_results_queue

# Email (Gmail SMTP для верификации преподавателей)
# Используй App Password: Google Account -> Security -> 2FA -> App passwords
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=YOUR_GMAIL@gmail.com
spring.mail.password=YOUR_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Допустимый домен для регистрации преподавателей.
# Оставить пустым чтобы принимать любой email (для тестирования).
sapsr.teacher.allowed-domain=@bsuir.by

logging.level.org.telegram=INFO
